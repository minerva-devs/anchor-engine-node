# .gitignore

# Dependencies - ignore all node_modules directories (including subdirs)
/node_modules/
mcp-server/node_modules/
scripts/node_modules/
engine/node_modules/

# Logs and build artifacts
/dist/
*.log
npm-debug.log*
yarn-error.log*

# Test outputs (always ignore)
test-output.txt
tests/vitest-setup.ts
engine-build-output.txt
engine-direct-tests.txt
engine-error.txt
npx-vitest-results.txt
vitest-from-root.txt
pnpm-start-tests.bat
test-results.txt
vite-aliases.txt
start_output.txt

# Temp files (common patterns)
temp_*.txt
temp_*.ts
temp_*.js
tmp_*.json
*.tmp

# Development tools - NOT project data (keep out of repo)
.vscode/
.idea/
.cline/

# QwenPaw agent configuration (sensitive - never commit)
agent.json
.qwenpaw/
.qwenpaw/*
!qwen-mcp-config.json # Keep MCP config for dev

# Agent memory files (local use only)
memory/*.md

# Skills - QwenPaw plugins (local use only, not for commit)
skills/

# Reme agent store
.reme_store_v1

# Skill system
.skill.json.lock

# Zenodo metadata (keep - useful for publishing)
.zenodo.json



# ============================================
# Runtime Data Directories (now in .anchor/)
# These should be rebuilt in C:\Users\<user>\.anchor\
# ============================================

# Anchor root directory (expanded path)
${anchor_root}/

# Agent directories
.jules/
.tooling/

# Runtime data - all moved to .anchor structure
AEN/
backup/
benchmarks/
dialog/
distillation-v2-temp/
embedding_cache/
engines/
file_store/
logs/
media/
memory/
notebook/
orchestration/
reports/
sessions/
test_minimal_db/
tool_result/
tool_results/
user_data/

# Runtime data files - moved to .anchor
chats.json
distillation-output.json
heartbeat.md
test-settings.json

# Test artifacts
engine-build-output.txt
engine-direct-tests.txt
engine-error.txt
engine-rebuild-output*.txt
engine-root-tests.txt
engine-tests-junit.xml
engine-tests.txt
npx-vitest-results.txt
pnpm-start-tests.bat
test-results.txt
vite-aliases.txt
vitest-from-root.txt

# Temp/bug files
$null
filename.endsWith(ext)))

# ============================================
# Agent/IDE config files
# ============================================
agent.json
skill.json

# Mission directories (development/testing artifacts)
missions/

# QwenPaw agent configuration (sensitive - never commit)
BOOTSTRAP.md
MEMORY.md
PROFILE.md
SOUL.md
AGENTS.md
.qwenpaw/
.qwenpaw/*
!qwen-mcp-config.json # Keep MCP config for dev

# ============================================
# .anchor runtime data (all paths configured via user_settings.json)
# ============================================
.anchor/

# ============================================
# Docker config (KEEP - needed for docker users)
# ============================================
user_settings.docker.json # Keep for Docker setup

# ============================================
# Source code directories (KEEP)
# ============================================



# Engine build artifacts (source is tracked)
engine/node_modules/
engine/build/
engine/dist/
engine/src/native/

# Native module dependencies (Rust WASM instead of C++)
engine/src/native/node_modules/
