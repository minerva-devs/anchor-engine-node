logs/
*.log
npm-debug.log*
pnpm-debug.log*

# Runtime data
engine/context_data/
mirrored_brain/
inbox/
external-inbox/
backups/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Test
coverage/
*.test.ts
*.test.js
tests/

# Documentation (not needed for runtime)
docs/
*.md
!README.md

# Development configs
.env
.env.local
.env.*.local

# Temporary files
tmp/
temp/
*.tmp
