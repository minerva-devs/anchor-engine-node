{
  "orchestrator": {
    "enabled": true,
    "description": "Model-agnostic orchestration layer for bolt-memory",
    "default_provider": "llama_cpp",
    "providers": {
      "llama_cpp": {
        "name": "llama.cpp",
        "type": "local",
        "server_binary": "/data/data/com.termux/files/usr/bin/llama-server",
        "default_port": 8080,
        "api_endpoint": "/completion",
        "models": [
          {
            "name": "Qwen 3.5 2B Instruct",
            "path": "/data/data/com.termux/files/home/models/qwen3.5-2b-instruct-q4_k_m.gguf",
            "context_size": 8192,
            "default": true
          },
          {
            "name": "Custom GGUF",
            "path": "",
            "context_size": 8192,
            "default": false
          }
        ],
        "settings": {
          "threads": 4,
          "gpu_layers": 0,
          "temperature": 0.7,
          "max_tokens": 2048
        }
      },
      "ollama": {
        "name": "Ollama",
        "type": "local",
        "base_url": "http://localhost:11434",
        "api_endpoint": "/api/generate",
        "models": [],
        "settings": {
          "temperature": 0.7,
          "max_tokens": 2048
        }
      },
      "lm_studio": {
        "name": "LM Studio",
        "type": "local",
        "base_url": "http://localhost:1234",
        "api_endpoint": "/v1/completions",
        "models": [],
        "settings": {
          "temperature": 0.7,
          "max_tokens": 2048
        }
      },
      "openai_compatible": {
        "name": "OpenAI Compatible",
        "type": "remote",
        "base_url": "",
        "api_key": "",
        "api_endpoint": "/v1/completions",
        "models": [],
        "settings": {
          "temperature": 0.7,
          "max_tokens": 2048
        }
      }
    },
    "system_prompts": {
      "orchestrator": "You are an AI orchestrator. You help break down tasks, make decisions, and track progress. Be concise and practical.",
      "researcher": "You are a research assistant. You analyze information, find patterns, and provide insights. Cite sources when available.",
      "coder": "You are a coding assistant. You write clean, efficient code and explain your decisions. Follow best practices.",
      "planner": "You are a planning assistant. You help create actionable plans with clear steps and timelines."
    },
    "bolt_memory": {
      "url": "http://localhost:3161",
      "api_key": "bolt-memory-secret",
      "auto_save": true,
      "auto_search": true,
      "checkpoint_on_complete": true
    }
  }
}
